# Etherscan API-Key (kostenlos registrierbar unter https://etherscan.io/apis)
# Niemals echte Keys committen - diese Datei ist nur eine Vorlage.
ETHERSCAN_API_KEY=your_api_key_here

# Optionale Overrides (Defaults siehe src/api_client/etherscan_client.py)
# ETHERSCAN_BASE_URL=https://api.etherscan.io/v2/api
# ETHERSCAN_CHAIN_ID=1
# Default 3 req/s - im Live-Test mit dem kostenlosen Tier beobachtetes
# tatsaechliches Limit ("Max calls per sec rate limit reached (3/sec)").
# Retry mit Backoff faengt Ueberschreitungen ohnehin ab.
# ETHERSCAN_RATE_LIMIT_RPS=3

