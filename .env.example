# Etherscan API-Key (kostenlos registrierbar unter https://etherscan.io/apis)
# Niemals echte Keys committen - diese Datei ist nur eine Vorlage.
#
# Etherscan API V2 deckt mehrere EVM-Chains (aktuell: Ethereum Mainnet,
# Arbitrum One - siehe src/api_client/chains.py) ueber DENSELBEN Key und
# Endpunkt ab. Es wird deshalb KEIN zweiter/chain-spezifischer API-Key
# benoetigt - die Chain wird pro Import ueber --chain (CLI) bzw. das
# "chain"-Feld im Web-Request gewaehlt, nicht ueber .env.
ETHERSCAN_API_KEY=your_api_key_here

# Optionale Overrides (Defaults siehe src/api_client/etherscan_client.py)
# ETHERSCAN_BASE_URL=https://api.etherscan.io/v2/api
# Default 3 req/s - im Live-Test mit dem kostenlosen Tier beobachtetes
# tatsaechliches Limit ("Max calls per sec rate limit reached (3/sec)").
# Live gegen Arbitrum One verifiziert: dasselbe Limit gilt pro API-Key
# UEBER ALLE CHAINS HINWEG gemeinsam, nicht pro Chain (siehe
# docs/adr/0004-multi-chain-support.md) - deshalb ein einziger globaler
# Wert statt chain-spezifischer Overrides. Retry mit Backoff faengt
# Ueberschreitungen ohnehin ab.
# ETHERSCAN_RATE_LIMIT_RPS=3

