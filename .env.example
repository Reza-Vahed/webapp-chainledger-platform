# Etherscan API-Key (kostenlos registrierbar unter https://etherscan.io/apis)
# Niemals echte Keys committen - diese Datei ist nur eine Vorlage.
ETHERSCAN_API_KEY=your_api_key_here

# Optionale Overrides (Defaults siehe src/api_client/etherscan_client.py)
